<Page
    x:Class="LaunchDeck.Widget.LaunchDeckWidget"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:LaunchDeck.Widget.Models"
    Background="#202020"
    RequestedTheme="Dark">

    <Page.Resources>
        <SolidColorBrush x:Key="TileBackground" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="TileBackgroundHover" Color="#383838"/>
        <SolidColorBrush x:Key="TileBackgroundPressed" Color="#252525"/>
        <SolidColorBrush x:Key="ButtonBackground" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#383838"/>
        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#252525"/>
        <SolidColorBrush x:Key="ButtonBorderBrush" Color="#1FFFFFFF"/>
        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#1FFFFFFF"/>
        <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#14FFFFFF"/>
        <SolidColorBrush x:Key="TileFocusBorder" Color="#60FFFFFF"/>
        <SolidColorBrush x:Key="LaunchSuccessBrush" Color="#4D107C10"/>
        <SolidColorBrush x:Key="LaunchFailureBrush" Color="#4DC42B1C"/>
    </Page.Resources>

    <Grid Padding="8">
        <!-- Normal state: grid of items -->
        <ScrollViewer x:Name="ItemsScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="Visible">
            <GridView x:Name="ItemsGrid"
                      ItemsSource="{x:Bind Items}"
                      SelectionMode="Single"
                      IsItemClickEnabled="True"
                      ItemClick="OnItemClick"
                      HorizontalAlignment="Center"
                      XYFocusKeyboardNavigation="Enabled"
                      SingleSelectionFollowsFocus="True"
                      IsTabStop="True"
                      TabNavigation="Once">
                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem">
                        <Setter Property="IsTabStop" Value="True"/>
                        <Setter Property="UseSystemFocusVisuals" Value="False"/>
                        <Setter Property="FocusVisualPrimaryBrush" Value="Transparent"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                    </Style>
                </GridView.ItemContainerStyle>
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid MaximumRowsOrColumns="4" Orientation="Horizontal"
                                       ItemWidth="88" ItemHeight="88"
                                       HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="models:LaunchItem">
                        <Grid x:Name="TileRoot" Width="80" Height="80"
                              CornerRadius="8" Padding="4"
                              Background="{StaticResource TileBackground}"
                              PointerEntered="OnTilePointerEntered"
                              PointerExited="OnTilePointerExited"
                              PointerPressed="OnTilePointerPressed"
                              PointerReleased="OnTilePointerReleased"
                              GotFocus="OnTileGotFocus"
                              LostFocus="OnTileLostFocus"
                              RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <CompositeTransform/>
                            </Grid.RenderTransform>

                            <!-- Focus/selection indicator -->
                            <Border x:Name="FocusBorder"
                                    CornerRadius="8"
                                    BorderBrush="{StaticResource TileFocusBorder}"
                                    BorderThickness="2"
                                    Opacity="0"
                                    IsHitTestVisible="False"
                                    Margin="-2"/>

                            <Border x:Name="FeedbackOverlay"
                                    CornerRadius="8"
                                    Opacity="0"
                                    IsHitTestVisible="False"/>

                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Spacing="4">
                                <Image Source="{x:Bind IconSource, Mode=OneWay}"
                                       Width="36" Height="36"
                                       HorizontalAlignment="Center"
                                       Stretch="Uniform" />
                                <TextBlock Text="{x:Bind Name}"
                                           FontSize="12"
                                           TextAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           MaxLines="1" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </ScrollViewer>

        <!-- Edit config button -->
        <Button x:Name="EditButton"
                Content="&#xE713;"
                FontFamily="Segoe MDL2 Assets"
                FontSize="16"
                Width="40" Height="40"
                CornerRadius="20"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,8,8"
                Click="OnEditClick"
                ToolTipService.ToolTip="Edit configuration" />

        <!-- Loading state -->
        <TextBlock x:Name="LoadingState"
                   Text="Loading..."
                   Visibility="Collapsed"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   FontSize="14"
                   Foreground="#C5FFFFFF" />

        <!-- Empty/error state -->
        <StackPanel x:Name="EmptyState"
                    Visibility="Collapsed"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="8"
                    Padding="16">
            <TextBlock x:Name="EmptyStateTitle"
                       Text="No apps configured"
                       FontSize="14" FontWeight="SemiBold"
                       TextAlignment="Center" />
            <TextBlock x:Name="EmptyStateMessage"
                       FontSize="12"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Foreground="#C5FFFFFF" />
        </StackPanel>
    </Grid>
</Page>
