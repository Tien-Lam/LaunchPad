<Window x:Class="LaunchPad.Companion.Editor.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LaunchPad — Config Editor"
        Width="500" Height="450"
        MinWidth="400" MinHeight="350"
        WindowStartupLocation="CenterScreen"
        ThemeMode="Dark">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PresentationFramework.Fluent;component/Themes/Fluent.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="FieldLabel" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                <Setter Property="Margin" Value="0,0,0,4"/>
            </Style>
            <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBackgroundBrush}"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel>
        <!-- Bottom bar -->
        <Border DockPanel.Dock="Bottom" Padding="12,8"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock x:Name="ItemCountLabel" Text="0 items"
                           FontSize="11" Opacity="0.5"
                           VerticalAlignment="Center"/>
                <Button x:Name="SaveButton" Content="Save and Refresh"
                        Style="{DynamicResource AccentButtonStyle}"
                        HorizontalAlignment="Right" DockPanel.Dock="Right"
                        Click="OnSaveClick"/>
            </DockPanel>
        </Border>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Padding="8,6"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="AddButton" Content="+ Add ▾"
                        Style="{DynamicResource AccentButtonStyle}"
                        Click="OnAddButtonClick" Margin="0,0,4,0"/>
                <Separator Margin="4,0"/>
                <Button x:Name="MoveUpButton" Content="&#x25B2;"
                        Click="OnMoveUpClick" Margin="4,0,2,0" Padding="8,4"/>
                <Button x:Name="MoveDownButton" Content="&#x25BC;"
                        Click="OnMoveDownClick" Margin="0,0,4,0" Padding="8,4"/>
                <Separator Margin="4,0"/>
                <Button x:Name="RemoveButton" Content="Remove" Style="{StaticResource DangerButton}"
                        Click="OnRemoveClick" Margin="4,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Main content: list + edit panel -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Add menu dropdown (overlays content when visible) -->
            <Border x:Name="AddMenu" Visibility="Collapsed"
                    Grid.ColumnSpan="3"
                    VerticalAlignment="Top" HorizontalAlignment="Left"
                    Margin="8,0,0,0" Panel.ZIndex="10"
                    CornerRadius="4" Padding="2"
                    Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                    BorderThickness="1">
                <StackPanel>
                    <Button Content="EXE Application" Click="OnAddExeClick"
                            HorizontalContentAlignment="Left" Padding="12,6"
                            BorderThickness="0" Background="Transparent"/>
                    <Button Content="URL" Click="OnAddUrlClick"
                            HorizontalContentAlignment="Left" Padding="12,6"
                            BorderThickness="0" Background="Transparent"/>
                    <Button Content="Store App" Click="OnAddStoreClick"
                            HorizontalContentAlignment="Left" Padding="12,6"
                            BorderThickness="0" Background="Transparent"/>
                </StackPanel>
            </Border>

            <!-- Left: Item list -->
            <ListBox x:Name="ItemList" Grid.Column="0"
                     BorderThickness="0"
                     AllowDrop="True"
                     SelectionChanged="OnItemSelectionChanged"
                     PreviewMouseLeftButtonDown="OnListPreviewMouseDown"
                     PreviewMouseMove="OnListPreviewMouseMove"
                     Drop="OnListDrop"
                     DragOver="OnListDragOver">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="2,2">
                            <TextBlock Text="⠿" FontSize="14" Opacity="0.3"
                                       VerticalAlignment="Center" Margin="0,0,6,0"
                                       Cursor="SizeAll"
                                       ToolTip="Drag to reorder"/>
                            <Grid Width="24" Height="24" Margin="0,0,8,0">
                                <!-- Icon image (visible when loaded) -->
                                <Image Source="{Binding IconPath}" Width="24" Height="24"
                                       Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                <!-- Fallback text badge (visible when no icon) -->
                                <Border CornerRadius="3" Opacity="0.6"
                                        Visibility="{Binding FallbackVisibility}"
                                        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
                                    <TextBlock Text="{Binding TypeIcon}"
                                               FontSize="10" FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontSize="12"/>
                                <TextBlock Text="{Binding Type}" FontSize="10" Opacity="0.5"/>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Separator -->
            <GridSplitter Grid.Column="1" Width="1" HorizontalAlignment="Center"
                          Background="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"/>

            <!-- Right: Edit panel -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="EditPanel" Margin="16" Visibility="Collapsed">
                    <TextBlock Text="NAME" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="NameBox" Margin="0,0,0,14"/>

                    <TextBlock Text="TYPE" Style="{StaticResource FieldLabel}"/>
                    <TextBlock x:Name="TypeLabel" Opacity="0.5"
                               FontSize="13" Margin="0,0,0,14"
                               Padding="6,5"/>

                    <TextBlock Text="PATH" Style="{StaticResource FieldLabel}"/>
                    <DockPanel Margin="0,0,0,14">
                        <Button x:Name="BrowsePathButton" Content="Browse"
                                DockPanel.Dock="Right" Margin="4,0,0,0"
                                Click="OnBrowsePathClick"/>
                        <TextBox x:Name="PathBox"/>
                    </DockPanel>

                    <StackPanel x:Name="ArgsPanel">
                        <TextBlock Text="ARGUMENTS" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="ArgsBox" Margin="0,0,0,14"/>
                    </StackPanel>

                    <TextBlock Text="CUSTOM ICON" Style="{StaticResource FieldLabel}"/>
                    <DockPanel Margin="0,0,0,14">
                        <Button Content="Browse"
                                DockPanel.Dock="Right" Margin="4,0,0,0"
                                Click="OnBrowseIconClick"/>
                        <TextBox x:Name="IconBox"/>
                    </DockPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>
