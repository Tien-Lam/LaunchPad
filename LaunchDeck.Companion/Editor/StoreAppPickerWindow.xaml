<Window x:Class="LaunchDeck.Companion.Editor.StoreAppPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Store App"
        Width="400" Height="500"
        MinWidth="300" MinHeight="300"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="EditorTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource PageBackground}">
        <DockPanel Margin="24,20">
            <!-- Page header -->
            <TextBlock Text="Select Store App" Style="{StaticResource PageTitle}"
                       DockPanel.Dock="Top" Margin="0,0,0,12"/>

            <!-- Search box -->
            <TextBox x:Name="SearchBox"
                     DockPanel.Dock="Top"
                     Margin="0,0,0,12"
                     TextChanged="OnSearchTextChanged"/>

            <!-- Bottom buttons -->
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="OK" Width="80" Margin="0,0,8,0"
                        Style="{DynamicResource AccentButtonStyle}"
                        Click="OnOkClick" x:Name="OkButton" IsEnabled="False"/>
                <Button Content="Cancel" Width="80"
                        Click="OnCancelClick"/>
            </StackPanel>

            <!-- Loading indicator -->
            <TextBlock x:Name="LoadingText" Text="Loading installed apps..."
                       DockPanel.Dock="Top"
                       HorizontalAlignment="Center"
                       Margin="0,20,0,0"
                       Foreground="{StaticResource TextSecondary}"/>

            <!-- App list -->
            <ListBox x:Name="AppList"
                     BorderThickness="0"
                     Background="Transparent"
                     SelectionChanged="OnSelectionChanged"
                     MouseDoubleClick="OnListDoubleClick"
                     Margin="0,4,0,0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="4,4">
                            <Grid Width="32" Height="32" Margin="0,0,10,0">
                                <Image Source="{Binding IconPath}" Width="32" Height="32"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <Border CornerRadius="4" Opacity="0.6"
                                        Visibility="{Binding FallbackVisibility}"
                                        Background="{StaticResource FallbackBadge}">
                                    <TextBlock Text="APP" FontSize="10" FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondary}"/>
                                </Border>
                            </Grid>
                            <TextBlock Text="{Binding Name}" FontSize="13"
                                       Foreground="{StaticResource TextPrimary}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Grid>
</Window>
